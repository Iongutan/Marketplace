@model Marketplace.Domain.Entities.Product
@using Marketplace.BusinessLogic.Singletons
@{
    ViewData["Title"] = "Finalizare comandă";
    var product = ViewBag.Product as Marketplace.Domain.Entities.Product ?? Model;
    var settings = MarketplaceSettings.Instance;
}

<style>
    .checkout-card-premium {
        background: #fff;
        border: 1px solid var(--border-color);
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: var(--shadow-lg);
    }

    .gateway-option {
        border: 1px solid var(--border-color);
        border-radius: 1rem;
        padding: 1.25rem;
        cursor: pointer;
        transition: var(--transition);
        background: var(--bg-alt);
        text-align: center;
        width: 100%;
        display: block;
        position: relative;
    }

    .gateway-option:hover {
        border-color: var(--text-main);
        background: #fff;
    }

    .gateway-option.active {
        border-color: var(--accent-color);
        background: #eff6ff;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .gateway-option input[type="radio"] {
        display: none;
    }

    .gateway-logo {
        font-size: 1.25rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
    }

    .pattern-info-tag {
        background: var(--bg-alt);
        color: var(--text-main);
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        padding: 0.75rem 1.25rem;
        margin-bottom: 2rem;
        font-size: 0.875rem;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-8">


        <div class="checkout-card-premium">
            <div class="mb-4">
                <h2 class="fw-bold mb-1">Finalizare Comandă</h2>
                <p class="text-muted">Revizuiește detaliile și alege metoda de plată</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mb-4">@TempData["Error"]</div>
            }

            <div class="card-minimal bg-light border-0 p-4 mb-5 rounded-4">
                <div class="row align-items-center">
                    <div class="col">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Produs selectat</div>
                        <h4 class="fw-bold mb-0">@product.Name</h4>
                        <div class="d-flex align-items-center gap-2 mt-2">
                            <span class="badge-premium @(product.IsDigital == true ? "badge-online" : "badge-clone")">
                                @(product.IsDigital == true ? "Digital" : "Fizic")
                            </span>
                            <span class="text-muted small">@product.Category</span>
                        </div>
                    </div>
                    <div class="col-auto text-end">
                        <div class="h3 fw-bold mb-0">@product.Price?.ToString("N0") @settings.DefaultCurrency</div>
                    </div>
                </div>
            </div>

            <form asp-controller="Order" asp-action="PlaceOrder" method="post">
                <input type="hidden" name="productId" value="@product.Id" />
                <input type="hidden" name="quantity" value="1" />

                <div class="mb-4">
                    <h6 class="fw-bold text-uppercase small mb-3 text-muted">Alege Metoda de Plată</h6>
                    <div class="row g-3" id="gatewayOptions">
                        <div class="col-md-4">
                            <label class="gateway-option active" id="lbl-paypal">
                                <input type="radio" name="paymentGateway" value="PayPal" checked
                                    onchange="selectGateway(this)" />
                                <div class="gateway-logo" style="color:#003087;">PayPal</div>
                                <div class="small text-muted fw-medium mt-1">PayPalAdapter</div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="gateway-option" id="lbl-stripe">
                                <input type="radio" name="paymentGateway" value="Stripe"
                                    onchange="selectGateway(this)" />
                                <div class="gateway-logo" style="color:#6366f1;">Stripe</div>
                                <div class="small text-muted fw-medium mt-1">StripeAdapter</div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="gateway-option" id="lbl-googlepay">
                                <input type="radio" name="paymentGateway" value="GooglePay"
                                    onchange="selectGateway(this)" />
                                <div class="gateway-logo" style="color:#0f172a;">G Pay</div>
                                <div class="small text-muted fw-medium mt-1">GooglePayAdapter</div>
                            </label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 btn-lg mt-2">
                    Confirmă Plata — @product.Price?.ToString("N0") @settings.DefaultCurrency
                </button>
            </form>
        </div>

        <div class="mt-4 text-center">
            <a asp-controller="Home" asp-action="Index" class="btn-link text-muted small text-decoration-none">
                ← Înapoi la catalogul Marketplace
            </a>
        </div>
    </div>
</div>
</div>
</div>

<script>
    function selectGateway(radio) {
        document.querySelectorAll('.gateway-option').forEach(b => b.classList.remove('active'));
        radio.closest('.gateway-option').classList.add('active');
    }
</script>
