<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Marketplace</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Marketplace.Web.styles.css" asp-append-version="true" />
</head>

<body class="animate-fade-in">

    <header>
        <nav class="navbar-minimal">
            <div class="container">
                <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🛒 Marketplace
                </a>
                
                <ul class="nav-links d-none d-md-flex">
                    <li><a class="nav-link-minimal" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="nav-link-minimal" asp-controller="Product" asp-action="Index">Browse Products</a></li>
                    
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li><a class="nav-link-minimal fw-bold" asp-controller="UserCabinet" asp-action="Index">My Cabinet</a></li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li><a class="nav-link-minimal text-danger" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a></li>
                        }
                        
                        <li class="ms-3">
                            <span class="nav-link-minimal text-muted">@User.Identity.Name</span>
                        </li>
                        <li>
                            <a class="btn btn-outline" asp-controller="Account" asp-action="Logout">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li><a class="nav-link-minimal" asp-controller="Account" asp-action="Login">Login</a></li>
                        <li>
                            <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Join Marketplace</a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1 py-5">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-minimal">
        <div class="container text-center">
            <p class="text-muted mb-0" style="font-size: 0.875rem;">
                &copy; 2026 🛒 Marketplace | <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
