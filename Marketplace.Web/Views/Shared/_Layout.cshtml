@using Marketplace.BusinessLogic.Singletons
@{
    var settings = MarketplaceSettings.Instance;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @settings.SiteName</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Marketplace.Web.styles.css" asp-append-version="true" />
</head>

<body class="animate-fade-in">

    <header>
        <nav class="navbar-minimal py-3">
            <div class="container d-flex align-items-center gap-4">
                <a class="brand flex-shrink-0" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="text-primary">Marketplace</span>
                </a>

                <div class="flex-grow-1 mx-2">
                    <form asp-controller="Home" asp-action="Index" method="get" class="d-flex">
                        <div class="input-group">
                            <input type="text" name="search" class="form-control border-end-0"
                                placeholder="Căutare în anunțuri"
                                value="@ViewContext.HttpContext.Request.Query["search"]">
                            <button class="btn btn-outline border-start-0 bg-white" type="submit">
                                <span class="opacity-50">Căutare</span>
                            </button>
                        </div>
                    </form>
                </div>

                <div class="d-flex align-items-center gap-3 flex-shrink-0">
                    <a asp-controller="Product" asp-action="Create" class="btn btn-success px-4"
                        style="background-color: #71b32d; border-color: #71b32d;">
                        Adaugă anunț
                    </a>

                    <ul class="nav-links m-0 p-0 d-none d-lg-flex">
                        <li><a class="nav-link-minimal" asp-controller="Catalog" asp-action="Index">Catalog</a></li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="nav-link-minimal text-danger" asp-controller="Admin"
                                        asp-action="Dashboard">Admin</a></li>
                            }
                            <li><a class="nav-link-minimal" asp-controller="UserCabinet" asp-action="Index">Cabinet</a></li>
                            <li><a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Logout">Ieșire</a></li>
                        }
                        else
                        {
                            <li><a class="btn btn-light btn-sm" asp-controller="Account"
                                    asp-action="Login">Autentificare</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1 py-5">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-minimal">
        <div class="container text-center">
            <p class="text-muted mb-0" style="font-size: 0.875rem;">
                &copy; 2026 @settings.SiteName
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
