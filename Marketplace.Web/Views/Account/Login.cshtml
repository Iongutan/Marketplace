@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center py-5">
    <div class="col-md-5">
        <div class="card card-minimal shadow-lg p-4 p-md-5">
            <div class="mb-4 text-center">
                <h2 class="fw-bold mb-1">Bine ai revenit</h2>
                <p class="text-muted">Introdu datele tale pentru a accesa contul.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4">@ViewBag.Error</div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="mb-3">
                    <label for="username" class="form-label">Nume utilizator</label>
                    <input type="text" name="username" id="username" class="form-control" placeholder="nume_utilizator"
                        required />
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label for="password" class="form-label">Parolă</label>
                    </div>
                    <input type="password" name="password" id="password" class="form-control" placeholder="••••••••"
                        required />
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-lg mb-4">
                    Autentificare
                </button>
            </form>

            <div class="text-center">
                <p class="text-muted small mb-0">
                    Nu ai un cont? <a asp-controller="Account" asp-action="Register" class="fw-bold">Înregistrează-te
                        acum</a>
                </p>
            </div>
        </div>
    </div>
</div>
