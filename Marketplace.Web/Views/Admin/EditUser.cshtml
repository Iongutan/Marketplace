@model Marketplace.Domain.Entities.User
@using Marketplace.Domain.Enums
@{
    ViewData["Title"] = "Editează Utilizator";
}

<div class="row g-4">
    <aside class="col-md-2">
        @await Html.PartialAsync("_CategorySidebar")
    </aside>

    <main class="col-md-10">
        <div class="mb-5 d-flex justify-content-between align-items-end">
            <div>
                <h1 class="display-5 fw-bold mb-1">Editează Utilizator</h1>
                <p class="text-muted small">Modifică detaliile contului pentru @Model.Username.</p>
            </div>
            <div class="mb-1">
                <a asp-action="Users" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i>Înapoi la Listă
                </a>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger rounded-4 border-0 mb-4">
                @ViewBag.Error
            </div>
        }

        <div class="card card-minimal shadow-sm border-0 p-4 bg-white rounded-4">
            <form asp-action="EditUser" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Nume Utilizator</label>
                        <input asp-for="Username" class="form-control rounded-3" placeholder="Ex: johndoe" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Email</label>
                        <input asp-for="Email" type="email" class="form-control rounded-3"
                            placeholder="Ex: john@example.com" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Rol Utilizator</label>
                        <select asp-for="Role" class="form-select rounded-3">
                            <option value="@UserRole.Client">Client</option>
                            <option value="@UserRole.Admin">Administrator</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Parolă Nouă (Opțional)</label>
                        <input name="newPassword" type="password" class="form-control rounded-3"
                            placeholder="Lasă gol pentru a păstra parola actuală" />
                    </div>
                </div>

                <div class="mt-5 border-top pt-4 text-end">
                    <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">
                        Salvează Modificările
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>
