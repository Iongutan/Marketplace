@model IEnumerable<Marketplace.Domain.Entities.User>
@{
    ViewData["Title"] = "Gestiune Utilizatori";
}

<style>
    /* Expand container just for this page */
    @@media (min-width: 1200px) {
        .container {
            max-width: 95% !important;
            transition: max-width 0.3s ease;
        }
    }

    .table-compact td,
    .table-compact th {
        padding-left: 1rem !important;
        padding-right: 1rem !important;
    }

    .btn-xs {
        font-size: 0.75rem;
        line-height: 1.5;
        border-radius: 0.3rem;
    }

    .bg-alt {
        background-color: #f8fafc;
    }
</style>

<div class="row g-4">
    <aside class="col-md-2">
        @await Html.PartialAsync("_CategorySidebar")
    </aside>

    <main class="col-md-10">
        <div class="mb-5 d-flex justify-content-between align-items-end">
            <div>
                <h1 class="display-5 fw-bold mb-1">Gestiune Utilizatori</h1>
                <p class="text-muted small">Administrare conturi și curățare anunțuri asociate.</p>
            </div>
            <div class="mb-1">
                <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i>Înapoi la Dashboard
                </a>
            </div>
        </div>

        <div class="card card-minimal shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 table-compact">
                    <thead>
                        <tr class="bg-alt">
                            <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Utilizator</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Email</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted text-center">Rol</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted text-center"
                                style="min-width: 140px;">Data Înscrierii</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4"
                                style="min-width: 200px;">Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-3 me-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center"
                                            style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div class="fw-bold text-main small">@user.Username</div>
                                    </div>
                                </td>
                                <td class="text-muted small">@user.Email</td>
                                <td class="text-center">
                                    <span
                                        class="badge @(user.Role.ToString() == "Admin" ? "bg-danger" : "bg-light text-muted border") rounded-pill px-2 small">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="text-center text-muted small">
                                    @user.CreatedDate.ToString("dd.MM.yyyy")
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-action="EditUser" asp-route-id="@user.Id"
                                            class="btn btn-outline-primary btn-xs px-2 py-1 small">
                                            Editează
                                        </a>
                                        @if (user.Username != User.Identity.Name) // Don't let admin delete themselves
                                        {
                                            <a asp-action="DeleteUser" asp-route-id="@user.Id"
                                                class="btn btn-light btn-xs px-2 py-1 small text-danger"
                                                onclick="return confirm('ATENȚIE! Ștergerea utilizatorului va șterge automat și toate anunțurile acestuia. Continui?')">
                                                Șterge
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">Contul tău</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
