@model Marketplace.Domain.Entities.Product

@{
    ViewData["Title"] = "Admin - Edit Product";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 card-minimal">
            <div class="card-body p-5">
                <div class="mb-4">
                    <span class="badge bg-danger mb-2">Admin Mode</span>
                    <h2 class="fw-bold">Editează Produsul #@Model.Id</h2>
                    <p class="text-muted">Modificarea acestui produs va afecta listarea publică a utilizatorului.</p>
                </div>

                <form asp-action="EditProduct" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="CreatedDate" />

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label fw-semibold">Nume Produs</label>
                            <input asp-for="Name" class="form-control" placeholder="ex: iPhone 15 Pro" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label fw-semibold">Categorie</label>
                            <select asp-for="Category" class="form-select">
                                <option value="">Selectează categoria</option>
                                <option value="Telefoane">Telefoane</option>
                                <option value="Laptopuri">Laptopuri</option>
                                <option value="Audio">Audio</option>
                                <option value="Accesorii">Accesorii</option>
                                <option value="Software">Software (Online)</option>
                                <option value="Servicii">Servicii</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Brand" class="form-label fw-semibold">Brand</label>
                            <input asp-for="Brand" class="form-control" placeholder="ex: Apple, Samsung, Sony"
                                list="brandsList" />
                            <datalist id="brandsList">
                                <option value="Apple" />
                                <option value="Samsung" />
                                <option value="Sony" />
                                <option value="Microsoft" />
                                <option value="Dell" />
                                <option value="Logitech" />
                            </datalist>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-semibold">Preț</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                            </div>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label fw-semibold">Stoc</label>
                            <input asp-for="Stock" type="number" class="form-control" required />
                            <span asp-validation-for="Stock" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="ImageUrl" class="form-label fw-semibold">URL Imagine</label>
                            <input asp-for="ImageUrl" class="form-control"
                                placeholder="https://exemplu.com/imagine.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-semibold">Descriere</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input type="checkbox" name="IsDigital" value="true" class="form-check-input"
                                    id="flexSwitchCheckDefault" @(Model.IsDigital == true ? "checked" : "")>
                                <input type="hidden" name="IsDigital" value="false">
                                <label class="form-check-label" for="flexSwitchCheckDefault">Acest produs este Digital
                                    (Online)</label>
                            </div>
                        </div>

                        <div class="col-md-12 mt-4">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary px-5 btn-lg">Salvează Modificările</button>
                                <a asp-action="Dashboard" class="btn btn-outline px-4 btn-lg">Anulează</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
