@model Marketplace.Domain.Entities.Product

@{
    ViewData["Title"] = "Adaugă Produs";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="product-card-premium p-5 shadow-lg border-0">
            <div class="mb-5">
                <h1 class="display-6 fw-bold">Adaugă un produs nou</h1>
                <p class="text-muted fs-5">Completează detaliile de mai jos pentru a lista produsul tău pe marketplace.
                </p>
            </div>

            <form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-4">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label text-uppercase small letter-spacing-wide">Nume
                        Produs</label>
                    <input asp-for="Name" class="form-control form-control-lg border-light-subtle rounded-3"
                        placeholder="ex: iPhone 15 Pro" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Category"
                        class="form-label text-uppercase small letter-spacing-wide">Categorie</label>
                    <select asp-for="Category" class="form-select form-select-lg border-light-subtle rounded-3">
                        <option value="Interior">Interior</option>
                        <option value="Produse Fizice">Produse Fizice</option>
                        <option value="Produse Digitale">Produse Digitale</option>
                        <option value="Servicii">Servicii</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label asp-for="Brand" class="form-label text-uppercase small letter-spacing-wide">Brand</label>
                    <input asp-for="Brand" class="form-control form-control-lg border-light-subtle rounded-3"
                        placeholder="ex: Apple, Samsung" />
                </div>

                <div class="col-md-3">
                    <label asp-for="Price" class="form-label text-uppercase small letter-spacing-wide">Preț
                        (MDL)</label>
                    <input asp-for="Price" type="number" step="1"
                        class="form-control form-control-lg border-light-subtle rounded-3" required />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Stock" class="form-label text-uppercase small letter-spacing-wide">Stoc</label>
                    <input asp-for="Stock" type="number"
                        class="form-control form-control-lg border-light-subtle rounded-3" required />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ImageUrl" class="form-label text-uppercase small letter-spacing-wide">Sau URL
                        Imagine</label>
                    <input asp-for="ImageUrl" class="form-control form-control-lg border-light-subtle rounded-3"
                        placeholder="https://..." />
                </div>

                <div class="col-md-6">
                    <label class="form-label text-uppercase small letter-spacing-wide">Încarcă Imagine
                        (Opțional)</label>
                    <input type="file" name="ImageFile"
                        class="form-control form-control-lg border-light-subtle rounded-3" accept="image/*" />
                </div>

                <div class="col-md-12">
                    <label asp-for="Description" class="form-label text-uppercase small letter-spacing-wide">Descriere
                        Detaliată</label>
                    <textarea asp-for="Description" class="form-control border-light-subtle rounded-3" rows="6"
                        placeholder="Descrie produsul tău în detaliu..."></textarea>
                </div>

                <div class="col-md-12">
                    <div class="form-check form-switch p-3 bg-light rounded-3 d-flex align-items-center gap-3">
                        <input type="checkbox" name="IsDigital" value="true" class="form-check-input ms-0"
                            id="flexSwitchCheckDefault" @(Model?.IsDigital == true ? "checked" : "")
                            style="width: 3rem; height: 1.5rem;">
                        <input type="hidden" name="IsDigital" value="false">
                        <label class="form-check-label fw-bold mb-0" for="flexSwitchCheckDefault">Acest produs este
                            Digital</label>
                    </div>
                </div>

                <div class="col-md-12 mt-5">
                    <div class="d-flex gap-3">
                        <button type="submit"
                            class="btn btn-primary btn-lg px-5 py-3 rounded-3 shadow-sm border-0">Salvează
                            Produsul</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 py-3 rounded-3">Anulează</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .letter-spacing-wide {
        letter-spacing: 0.05em;
        color: #64748b;
    }

    .display-6 {
        letter-spacing: -0.025em;
    }
</style>
