@model IEnumerable<Marketplace.Domain.Entities.Product>

@{
    ViewData["Title"] = "My Cabinet";
}

<div class="row g-4">
    <aside class="col-md-3">
        @await Html.PartialAsync("_CategorySidebar")
    </aside>

    <main class="col-md-9">
        <div class="cabinet-header mb-5">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 fw-bold mb-1">Cabinet Personal</h1>
                    <p class="text-muted">Gestionează produsele tale și vizualizează performanța lor.</p>
                </div>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    Adaugă Produs Nou
                </a>
            </div>
        </div>

        <div class="row g-4">
            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5">
                    <div class="empty-state">
                        <h3>Nu ai niciun produs listat</h3>
                        <p class="text-muted mb-4">Începe să vinzi chiar acum prin adăugarea primului tău produs.</p>
                        <a asp-action="Create" class="btn btn-outline-primary">Adaugă primul produs</a>
                    </div>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-6">
                        <div class="product-card-premium">
                            <div class="image-container">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name"
                                        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                    <div class="w-100 h-100 d-none align-items-center justify-content-center bg-light">
                                        <span class="opacity-10 display-1 fw-bold">M</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                        <span class="opacity-10 display-1 fw-bold">M</span>
                                    </div>
                                }
                                <div class="badges-overlay">
                                    <span class="badge-premium @(item.IsDigital == true ? "badge-online" : "badge-clone")">
                                        @(item.IsDigital == true ? "Online" : "Fizic")
                                    </span>
                                </div>
                            </div>
                            <div class="brand-name">@(item.Brand ?? "MARKETPLACE")</div>
                            <h3 class="product-title">@item.Name</h3>
                            <p class="product-desc">@(item.Description ?? "Fără descriere.")</p>
                            <div class="card-footer-premium">
                                <div class="price-tag">@((item.Price ?? 0).ToString("N0")) MDL</div>
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                        class="btn btn-outline-primary btn-sm">Editează</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-light btn-sm text-danger"
                                        onclick="return confirm('Ești sigur că vrei să ștergi acest produs?')">Șterge</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </main>
</div>

@section Scripts {

}
