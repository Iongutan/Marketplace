@using Marketplace.BusinessLogic.Singletons
@{
    ViewData["Title"] = "Marketplace";
    var currentCategory = ViewBag.CurrentCategory as string;
    var currentSearch = ViewBag.CurrentSearch as string;
    var settings = MarketplaceSettings.Instance;
}

<div class="container mt-4">


    <div class="row g-4">
        <!-- Sidebar Categories -->
        <aside class="col-md-3">
            @await Html.PartialAsync("_CategorySidebar")
        </aside>

        <!-- Main Product Grid -->
        <main class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h5 class="fw-bold m-0 text-muted text-uppercase small">Recomandate</h5>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted">Niciun anunț găsit în această categorie.</p>
                    <a asp-action="Index" class="btn btn-outline btn-sm">Resetează filtrele</a>
                </div>
            }
            else
            {
                <div class="row g-4 row-cols-1 row-cols-md-3">
                    @foreach (var item in Model)
                    {
                        <div class="col">
                            <div class="product-card-premium">
                                <div class="image-container">
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name"
                                            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                        <div class="w-100 h-100 d-none align-items-center justify-content-center bg-light">
                                            <span class="opacity-10 display-1 fw-bold">M</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                            <span class="opacity-10 display-1 fw-bold">M</span>
                                        </div>
                                    }
                                    <div class="badges-overlay">
                                        @if (item.IsDigital == true)
                                        {
                                            <span class="badge-premium badge-online">Online</span>
                                        }
                                        <span class="badge-premium badge-clone">TOP</span>
                                    </div>
                                </div>
                                <div class="brand-name">@(item.Brand ?? "MARKETPLACE")</div>
                                <h3 class="product-title">@item.Name</h3>
                                <p class="product-desc">@(item.Description ?? "Fără descriere disponibilă.")</p>
                                <div class="card-footer-premium">
                                    <div class="price-tag">@((item.Price ?? 0).ToString("N0")) @settings.DefaultCurrency</div>
                                    <a asp-controller="Product" asp-action="Checkout" asp-route-id="@item.Id"
                                        class="btn-buy-premium text-decoration-none">Cumpără</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>

<style>
    .text-accent {
        color: #2563eb;
    }

    .text-accent:hover {
        color: #1d4ed8;
        text-decoration: underline !important;
    }

    .sidebar-categories li a {
        font-size: 0.95rem;
        transition: color 0.2s;
    }

    .home-product-card:hover .transition-transform {
        transform: scale(1.05);
    }

    .banner-card {
        border: 1px solid #e2e8f0;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .banner-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    }

    .object-fit-cover {
        object-fit: cover;
    }

    .transition-transform {
        transition: transform 0.3s ease;
    }
</style>
