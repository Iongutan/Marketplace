@model Marketplace.Domain.Entities.Product

@{
    ViewData["Title"] = "Create Product";
}

@{
    ViewData["Title"] = "Create Product";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-minimal shadow-sm border-0">
            <div class="card-body p-5">
                <div class="text-center mb-5">
                    <div class="display-3 mb-3">📦</div>
                    <h2 class="fw-bold mb-1">Create New Product</h2>
                    <p class="text-muted">Add a new product to your marketplace</p>
                </div>

                <form asp-action="Create" method="post">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label fw-semibold">Product Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter product name" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                placeholder="Enter product description"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-semibold">Price ($)</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00"
                                required />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label fw-semibold">Stock Quantity</label>
                            <input asp-for="Stock" type="number" class="form-control" placeholder="0" required />
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Brand" class="form-label fw-semibold">Brand</label>
                            <input asp-for="Brand" class="form-control" placeholder="e.g. Apple, Sony" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label fw-semibold">Category</label>
                            <select asp-for="Category" class="form-select">
                                <option value="Telefoane">Telefoane</option>
                                <option value="Laptopuri">Laptopuri</option>
                                <option value="Audio">Audio</option>
                                <option value="Accesorii">Accesorii</option>
                                <option value="Software">Software</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input type="checkbox" name="IsDigital" value="true" class="form-check-input"
                                    id="flexSwitchCheckDefault">
                                <input type="hidden" name="IsDigital" value="false">
                                <label class="form-check-label" for="flexSwitchCheckDefault">This is a Digital Product
                                    (Downloadable)</label>
                            </div>
                        </div>

                        <div class="col-md-12 mt-5">
                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-primary px-5 btn-lg flex-grow-1">✓ Save
                                    Product</button>
                                <a asp-action="Index" class="btn btn-outline px-4 btn-lg">Anulează</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
