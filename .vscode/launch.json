{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Marketplace.Web",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Marketplace.Web/bin/Debug/net10.0/Marketplace.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Marketplace.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Marketplace.Web/Views"
            }
        },
        {
            "name": "Launch Design Patterns Demo",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-demo",
            "program": "${workspaceFolder}/Marketplace.DesignPatterns.Demo/bin/Debug/net10.0/Marketplace.DesignPatterns.Demo.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Marketplace.DesignPatterns.Demo",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}